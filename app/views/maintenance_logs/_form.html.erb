<%= render "shared/form_errors", object: maintenance_log %>

<%= form_with model: [@flight_school, @aircraft, maintenance_log] do |f| %>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :logged_at, "Date", class: "form-label" %>
      <%= f.datetime_local_field :logged_at, class: "form-control", required: true %>
    </div>

    <div class="col-md-6 mb-3">
      <%= f.label :log_type, "Type", class: "form-label" %>
      <%= f.select :log_type, options_for_select([
        ["Routine", "routine"],
        ["Inspection", "inspection"],
        ["Repair", "repair"],
        ["Overhaul", "overhaul"],
        ["Other", "other"]
      ], maintenance_log.log_type), { prompt: "Select type..." }, class: "form-select", required: true %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :hobbs_hours, class: "form-label" %>
      <%= f.number_field :hobbs_hours, class: "form-control", step: 0.1 %>
    </div>

    <div class="col-md-6 mb-3">
      <%= f.label :tach_hours, class: "form-label" %>
      <%= f.number_field :tach_hours, class: "form-control", step: 0.1 %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :notes, class: "form-label" %>
    <%= f.text_area :notes, class: "form-control", rows: 3 %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", flight_school_aircraft_path(@flight_school, @aircraft), class: "btn btn-outline-secondary" %>
  </div>
<% end %>

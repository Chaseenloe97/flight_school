<h1 class="mb-4">Dashboard</h1>

<div class="row mb-4">
  <div class="col-md-4">
    <div class="card text-bg-primary shadow-sm">
      <div class="card-body text-center">
        <h5 class="card-title">Total Aircraft</h5>
        <p class="display-4"><%= @total_aircraft %></p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-bg-success shadow-sm">
      <div class="card-body text-center">
        <h5 class="card-title">Available</h5>
        <p class="display-4"><%= @aircraft_available %></p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-bg-danger shadow-sm">
      <div class="card-body text-center">
        <h5 class="card-title">Down</h5>
        <p class="display-4"><%= @aircraft_down %></p>
      </div>
    </div>
  </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>Your Flight Schools</h3>
  <%= link_to "Add Flight School", new_flight_school_path, class: "btn btn-primary" %>
</div>

<% if @flight_schools.any? %>
  <div class="row">
    <% @flight_schools.each do |school| %>
      <div class="col-md-6 mb-3">
        <div class="card shadow-sm">
          <div class="card-body">
            <h5 class="card-title"><%= link_to school.name, school %></h5>
            <p class="text-muted mb-2"><%= school.location %></p>
            <div class="d-flex gap-3">
              <span class="badge bg-primary"><%= school.aircrafts.size %> Aircraft</span>
              <% down_count = school.aircrafts.count(&:currently_down?) %>
              <% if down_count > 0 %>
                <span class="badge bg-danger"><%= down_count %> Down</span>
              <% else %>
                <span class="badge bg-success">All Available</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info">
    You haven't added any flight schools yet. <%= link_to "Create your first flight school", new_flight_school_path %>.
  </div>
<% end %>

<%= render "shared/form_errors", object: downtime_event %>

<%= form_with model: [@flight_school, @aircraft, downtime_event] do |f| %>
  <div class="mb-3">
    <%= f.label :reason_type, "Reason", class: "form-label" %>
    <%= f.select :reason_type, options_for_select([
      ["Maintenance", "maintenance"],
      ["Breakdown", "breakdown"],
      ["Inspection", "inspection"],
      ["Other", "other"]
    ], downtime_event.reason_type), { prompt: "Select reason..." }, class: "form-select", required: true %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :started_at, "Start Time", class: "form-label" %>
      <%= f.datetime_local_field :started_at, class: "form-control", required: true %>
    </div>

    <div class="col-md-6 mb-3">
      <%= f.label :ended_at, "Estimated End Time", class: "form-label" %>
      <%= f.datetime_local_field :ended_at, class: "form-control" %>
      <div class="form-text">Leave blank if unknown.</div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Describe the reason for downtime..." %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", flight_school_aircraft_path(@flight_school, @aircraft), class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-center mb-4">Log In</h2>

        <%= form_with url: login_path, method: :post, class: "needs-validation" do |f| %>
          <div class="mb-3">
            <%= f.label :email, class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true, autofocus: true %>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true %>
          </div>

          <div class="d-grid">
            <%= f.submit "Log In", class: "btn btn-primary" %>
          </div>
        <% end %>

        <p class="text-center mt-3 mb-0">
          Don't have an account? <%= link_to "Sign Up", signup_path %>
        </p>
      </div>
    </div>
  </div>
</div>

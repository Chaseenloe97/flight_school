<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h1><%= @flight_school.name %></h1>
    <p class="text-muted"><%= @flight_school.location %></p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_flight_school_path(@flight_school), class: "btn btn-outline-secondary" %>
    <%= link_to "Add Aircraft", new_flight_school_aircraft_path(@flight_school), class: "btn btn-primary" %>
  </div>
</div>

<!-- Search & Filter -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: flight_school_path(@flight_school), method: :get, local: true, class: "row g-3 align-items-end" do |f| %>
      <div class="col-md-4">
        <%= f.label :search, "Search", class: "form-label" %>
        <%= f.text_field :search, value: params[:search], class: "form-control", placeholder: "Tail number or model..." %>
      </div>
      <div class="col-md-3">
        <%= f.label :status, "Status", class: "form-label" %>
        <%= f.select :status, options_for_select([["All", ""], ["Available", "available"], ["Down", "down"]], params[:status]), {}, class: "form-select" %>
      </div>
      <div class="col-md-3">
        <%= f.submit "Filter", class: "btn btn-outline-primary" %>
        <%= link_to "Clear", flight_school_path(@flight_school), class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<h3 class="mb-3">Fleet (<%= @aircrafts.size %> Aircraft)</h3>

<% if @aircrafts.any? %>
  <div class="row">
    <% @aircrafts.each do |aircraft| %>
      <div class="col-md-6 col-lg-4 mb-3">
        <div class="card shadow-sm border-<%= aircraft.currently_down? ? 'danger' : 'success' %>">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h5 class="card-title mb-1"><%= aircraft.tail_number %></h5>
                <p class="text-muted mb-2"><%= aircraft.model %></p>
              </div>
              <% if aircraft.currently_down? %>
                <span class="badge bg-danger">DOWN</span>
              <% else %>
                <span class="badge bg-success">Available</span>
              <% end %>
            </div>
            <% if aircraft.currently_down? && aircraft.active_downtime_event %>
              <p class="small text-danger mb-2">
                <strong>Reason:</strong> <%= aircraft.active_downtime_event.reason_type.capitalize %>
                <% if aircraft.active_downtime_event.ended_at %>
                  <br><strong>Est. return:</strong> <%= aircraft.active_downtime_event.ended_at.strftime("%b %d, %Y %l:%M %p") %>
                <% end %>
              </p>
            <% end %>
            <div class="d-flex gap-2 flex-wrap">
              <%= link_to "View Details", flight_school_aircraft_path(@flight_school, aircraft), class: "btn btn-sm btn-outline-primary" %>
              <% if aircraft.currently_down? %>
                <%= button_to "Mark Available", mark_available_flight_school_aircraft_path(@flight_school, aircraft), method: :post, class: "btn btn-sm btn-success", data: { turbo_confirm: "Mark #{aircraft.tail_number} as available?" } %>
              <% else %>
                <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#markDownModal-<%= aircraft.id %>">
                  Mark Down
                </button>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Mark Down Modal -->
      <% unless aircraft.currently_down? %>
        <div class="modal fade" id="markDownModal-<%= aircraft.id %>" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">
              <%= form_with url: mark_down_flight_school_aircraft_path(@flight_school, aircraft), method: :post, local: true do |f| %>
                <div class="modal-header">
                  <h5 class="modal-title">Mark <%= aircraft.tail_number %> as Down</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                  <div class="mb-3">
                    <%= f.label :reason_type, "Reason", class: "form-label" %>
                    <%= f.select :reason_type, [["Breakdown", "breakdown"], ["Maintenance", "maintenance"], ["Inspection", "inspection"], ["Other", "other"]], {}, class: "form-select", required: true %>
                  </div>
                  <div class="mb-3">
                    <%= f.label :ended_at, "Estimated Return to Service", class: "form-label" %>
                    <%= f.datetime_local_field :ended_at, class: "form-control" %>
                    <div class="form-text">Leave blank if unknown.</div>
                  </div>
                  <div class="mb-3">
                    <%= f.label :description, "Details", class: "form-label" %>
                    <%= f.text_area :description, class: "form-control", rows: 2 %>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                  <%= f.submit "Mark as Down", class: "btn btn-danger" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info">
    <% if params[:search].present? || params[:status].present? %>
      No aircraft match your filter. <%= link_to "Clear filters", flight_school_path(@flight_school) %>.
    <% else %>
      No aircraft in this fleet yet. <%= link_to "Add your first aircraft", new_flight_school_aircraft_path(@flight_school) %>.
    <% end %>
  </div>
<% end %>

<%= link_to "Back to Dashboard", dashboard_path, class: "btn btn-link mt-3" %>
